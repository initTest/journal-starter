# Documentation for required environment secrets
# The journal-api expects these keys in a secret named 'journal-api-secrets'
apiVersion: v1
kind: Secret
metadata:
  name: journal-api-secrets
type: Opaque
stringData:
  # The full connection string for your database
  # Format: postgresql://<user>:<password>@<host>:<port>/<dbname>
  DATABASE_URL: "postgresql://user:password@host:5432/dbname"
  
  # Add other keys if your app grows (e.g., API_KEY, JWT_SECRET)
